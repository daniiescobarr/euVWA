<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Panel Admin Vulnerable</title>
</head>
<body>

    <h1>Panel de Administración Vulnerable</h1>

    <p>
        Acceso concedido mediante manipulación del parámetro role en la URL.
    </p>

    <h2>Usuarios registrados</h2>

    <table border="1" cellpadding="8">

        <tr>
            <th>ID</th>
            <th>Usuario</th>
            <th>Contraseña</th>
            <th>Rol</th>
        </tr>

        <% users.forEach(user => { %>

            <tr>
                <td><%= user.id %></td>
                <td><%= user.username %></td>
                <td><%= user.password %></td>
                <td><%= user.role %></td>
            </tr>

        <% }) %>

    </table>

    <br>

    <a href="/">Volver al inicio</a>

</body>
</html>